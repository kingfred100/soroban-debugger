{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RunCommandOutputEnvelope",
  "type": "object",
  "required": ["schema_version", "command", "status", "result", "error"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "command": {
      "type": "string",
      "const": "run"
    },
    "status": {
      "type": "string",
      "enum": ["success", "error"]
    },
    "result": {
      "type": ["object", "null"],
      "properties": {
        "result": {
          "type": "string"
        },
        "sha256": {
          "type": "string"
        },
        "budget": {
          "type": "object",
          "required": ["cpu_instructions", "memory_bytes"],
          "properties": {
            "cpu_instructions": { "type": "integer" },
            "memory_bytes": { "type": "integer" }
          }
        },
        "storage_diff": {
          "type": "object",
          "required": ["added", "modified", "deleted"],
          "properties": {
            "added": {
              "type": "object"
            },
            "modified": {
              "type": "object"
            },
            "deleted": {
              "type": "array"
            },
            "triggered_alerts": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "events": {
          "type": "array",
          "items": { "type": "object" }
        },
        "auth": {
          "type": "array",
          "items": { "type": "object" }
        },
        "mock_calls": {
          "type": "array",
          "items": { "type": "object" }
        },
        "ledger_entries": {
          "type": ["object", "null"]
        }
      }
    },
    "error": {
      "type": ["object", "null"],
      "properties": {
        "message": { "type": "string" }
      }
    }
  }
}
